<?xml version="1.0" encoding="UTF-8"?>
<plugin id="cordova-plugin-safariviewcontroller"
        version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>SafariViewController</name>

    <js-module src="www/SafariViewController.js" name="SafariViewController">
        <clobbers target="SafariViewController" />
    </js-module>

    <platform name="android">
        <config-file target="res/xml/config.xml" parent="/*">
            <feature name="SafariViewController">
                <param name="android-package" value="com.outsystems.safariviewcontroller.SafariViewController" />
            </feature>
        </config-file>

        <framework src="androidx.browser:browser:1.8.0" />

        <source-file src="src/android/SafariViewController.java" target-dir="app/src/main/java/com/outsystems/safariviewcontroller" />
    </platform>

    <platform name="ios">
            <config-file target="config.xml" parent="/*">
                <feature name="SafariViewController">
                    <param name="ios-package" value="SafariViewController" />
                </feature>
            </config-file>
        
            <preference name="UseSwiftLanguageVersion" default="5" />
        
            <source-file src="src/ios/SafariViewController.swift" />
            <framework src="SafariServices.framework" />
            <framework src="AuthenticationServices.framework" />
    </platform>
</plugin>
